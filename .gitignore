# ============================================================
# Frontend repository ignore rules
# ============================================================
# React + TypeScript + Vite を使うフロントエンド用。
# node_modules、dist、.env はGit管理しない。
# package-lock.json は依存関係固定のためGit管理する。
# ============================================================

# ------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------
# npm installで生成される依存パッケージ群。
# 非常に大きく、再生成可能なのでGit管理しない。
node_modules/

# ------------------------------------------------------------
# Build outputs
# ------------------------------------------------------------
# npm run buildで生成される本番用静的ファイル。
# Cloud Run等にはビルド結果を使うが、Gitではソースコードを管理する。
dist/
dist-ssr/

# ------------------------------------------------------------
# Environment variables / secrets
# ------------------------------------------------------------
# VITE_API_BASE_URLなどの環境依存値を入れる。
# 本番URLやローカルURLが人によって異なるため追跡しない。
.env
.env.*

# # 共有用テンプレートだけは追跡する。(しなくてよいことになったためコメントアウト)
# !.env.example

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ------------------------------------------------------------
# Test / coverage outputs
# ------------------------------------------------------------
coverage/

# ------------------------------------------------------------
# OS generated files
# ------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Editor / IDE local settings
# ------------------------------------------------------------
.vscode/
.idea/
EOF